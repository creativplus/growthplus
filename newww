        // Custom Video Review Logic
    function toggleReviewVideo(card) {
        const video = card.querySelector('video');
        const playOverlay = card.querySelector('.play-overlay');
        
        // Pause all other videos first so only one plays at a time
        document.querySelectorAll('#reviews video').forEach(v => {
            if (v !== video && !v.paused) {
                v.pause();
                v.closest('.bento-card').querySelector('.play-overlay').style.opacity = '1';
            }
        });

        // Toggle the clicked video
        if (video.paused) {
            video.play();
            playOverlay.style.opacity = '0'; // Hide play button
        } else {
            video.pause();
            playOverlay.style.opacity = '1'; // Show play button
        }
    }
