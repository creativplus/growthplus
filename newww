            border-color: rgba(116,23,49,0.2);
        }

        /* Luxury Button Hover State */
        .btn-brand {
            background: linear-gradient(135deg, #9C1F42 0%, #741731 100%);
            color: #FFFFFF;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 8px 20px -6px rgba(116, 23, 49, 0.5);
            position: relative;
            overflow: hidden;
        }
        .btn-brand::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.6s ease;
        }
        .btn-brand:hover {
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 12px 25px -8px rgba(156, 31, 66, 0.8);
            transform: translateY(-2px);
        }
        .btn-brand:hover::before {
            left: 100%;
